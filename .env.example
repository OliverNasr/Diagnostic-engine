# =========================================================
# Diagnostic Engine — environment variable reference
# Copy this file to .env and adjust values as needed.
# =========================================================

# ---- Service identity ----
SERVICE_NAME=Diagnostic Engine
SERVICE_VERSION=1.0.0
SERVICE_DESCRIPTION=Knowledge-based OBD-II Diagnostic Trouble Code lookup microservice.

# ---- Dataset ----
# Path is relative to the working directory inside the container (/app)
DATASET_PATH=data/dtc_dataset.csv

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# Set to "true" to enable uvicorn --reload (development only)
RELOAD=false

# ---- Logging ----
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
